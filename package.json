  "packageManager": "npm@11.14.1",
  "description": "Productivity dashboard for Obsidian with clock-aligned timers and task management",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "node esbuild.config.mjs production",
