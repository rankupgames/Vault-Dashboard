    "esbuild": "^0.28.1",
    "eslint": "^10.3.0",
    "happy-dom": "^20.9.0",
    "obsidian": "latest",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.59.1",
    "vitest": "^4.1.5"
  }
